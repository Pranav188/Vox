# --- Frontend Network Selection ---
# Switch between localhost and sepolia by changing VITE_ELECTION_NETWORK

# Localhost (default)
VITE_ELECTION_NETWORK=localhost
VITE_ELECTION_RPC_URL=http://127.0.0.1:8545
VITE_ELECTION_CHAIN_ID=31337
VITE_ELECTION_CHAIN_NAME=Hardhat Localhost
VITE_ELECTION_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Sepolia Testnet (uncomment and replace localhost values above)
# VITE_ELECTION_NETWORK=sepolia
# VITE_ELECTION_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# VITE_ELECTION_CHAIN_ID=11155111
# VITE_ELECTION_CHAIN_NAME=Sepolia
# VITE_ELECTION_CONTRACT_ADDRESS=<your-deployed-contract-address>

# --- Hardhat Sepolia Deployment ---
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<your-infura-project-id>
SEPOLIA_PRIVATE_KEY=<your-deployment-wallet-private-key>
